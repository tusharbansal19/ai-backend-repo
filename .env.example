# ============================================
#   Portfolio AI Backend — .env.example
#   Copy this file to .env and fill values
# ============================================

# ── HuggingFace (LLM + Embeddings — FREE) ──
HUGGINGFACE_API_KEY=hf_your_api_key_here
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── LangSmith Tracing (optional, FREE) ─────
LANGCHAIN_API_KEY=lsv2_your_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=Portfolio-AI

# ── FAISS (local, FREE — no setup needed) ─────
FAISS_INDEX_DIR=./faiss_index

# ── Email — Gmail SMTP ─────────────────────
# IMPORTANT: Use a Gmail App Password (not your regular password)
# Steps: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
OWNER_EMAIL=your-gmail@gmail.com     # Emails are ALWAYS sent here — never elsewhere
OWNER_NAME=Tushar

# ── Agent / Memory ─────────────────────────
# Memory is volatile (in-process dict) — no DB required
MAX_MEMORY_MESSAGES=20               # Sliding window: oldest messages dropped after 20
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.40

# ── CORS ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── GitHub Ingestion (optional) ────────────
GITHUB_TOKEN=ghp_your_github_token
GITHUB_USERNAME=your-github-username
GITHUB_REPOS=repo1,repo2

# ── Server ─────────────────────────────────
PORT=8000
ENVIRONMENT=development
